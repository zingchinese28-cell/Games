<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>汉字扫雷游戏</title>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: "Microsoft YaHei", sans-serif;
        }
        body {
            background-color: #f0f0f0;
            padding: 20px;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
        }
        .game-container {
            display: flex;
            background-color: #c0c0c0;
            border-radius: 8px;
            box-shadow: 0 0 20px rgba(0, 0, 0, 0.2);
            padding: 20px;
            position: relative;
            border: 3px outset #c0c0c0;
        }
        .player-info {
            display: flex;
            flex-direction: column;
            justify-content: center;
            width: 150px;
            padding: 0 15px;
        }
        .player-left {
            text-align: center;
        }
        .player-right {
            text-align: center;
        }
        .player-name, .player-score {
            margin: 15px 0;
            font-size: 20px;
            font-weight: bold;
        }
        .player-name input {
            font-size: 20px;
            padding: 8px;
            width: 100%;
            border: 2px inset #c0c0c0;
            border-radius: 4px;
            color: black;
            text-align: center;
            background-color: #e0e0e0;
        }
        .player-score input {
            font-size: 24px;
            padding: 8px;
            width: 100%;
            border: 2px inset #c0c0c0;
            border-radius: 4px;
            color: red;
            font-weight: bold;
            text-align: center;
            background-color: #e0e0e0;
        }
        .game-area {
            position: relative;
        }
        .controls {
            position: absolute;
            top: -45px;
            left: 50%;
            transform: translateX(-50%);
            z-index: 10;
        }
        #resetBtn {
            padding: 8px 12px;
            background-color: #c0c0c0;
            color: #000;
            border: 2px outset #c0c0c0;
            border-radius: 4px;
            cursor: pointer;
            font-size: 24px;
            transition: all 0.2s;
            width: 50px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        #resetBtn:hover {
            background-color: #d0d0d0;
        }
        #resetBtn:active {
            border: 2px inset #c0c0c0;
        }
        .game-board {
            display: grid;
            grid-template-columns: repeat(10, 40px);
            grid-template-rows: repeat(11, 40px);
            gap: 1px;
            border: 4px outset #c0c0c0;
            background-color: #c0c0c0;
            padding: 2px;
        }
        .chinese-cell {
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 2px outset #c0c0c0;
            background-color: #c0c0c0;
            font-size: 18px;
            font-weight: bold;
        }
        .chinese-cell input {
            width: 100%;
            height: 100%;
            text-align: center;
            font-size: 18px;
            border: none;
            background-color: transparent;
            outline: none;
            font-weight: bold;
        }
        .cell {
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            background-color: #c0c0c0;
            cursor: pointer;
            font-weight: bold;
            transition: all 0.1s;
            font-size: 14px;
            border: 2px outset #c0c0c0;
            user-select: none;
        }
        .cell:hover {
            background-color: #d0d0d0;
        }
        .cell.revealed {
            background-color: #c0c0c0;
            cursor: default;
            border: 1px solid #808080;
        }
        .cell.revealed.distance-1 {
            background-color: #ff0000; /* 正红色 */
            color: white;
        }
        .cell.revealed.distance-2 {
            background-color: #ff8000; /* 正橘色 */
            color: white;
        }
        .cell.revealed.distance-3-plus {
            background-color: #00cc00; /* 正绿色 */
            color: white;
        }
        .mine {
            background-color: #ff0000;
            color: white;
            font-size: 20px;
            border: 1px solid #808080;
        }
        .explosion-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 100;
            pointer-events: none;
        }
        .explosion {
            font-size: 150px;
            animation: explode 0.8s forwards;
            opacity: 1;
        }
        @keyframes explode {
            0% { transform: scale(0.1); opacity: 0; }
            100% { transform: scale(1.5); opacity: 1; }
        }
        .game-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.7);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 1000;
            color: white;
            font-size: 48px;
            flex-direction: column;
        }
        .restart-btn {
            margin-top: 20px;
            padding: 10px 20px;
            background-color: #4CAF50;
            color: white;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            font-size: 18px;
        }
    </style>
</head>
<body>
    <div class="game-container">
        <div class="player-info player-left">
            <div class="player-name">
                <input type="text" id="player1" placeholder="玩家1">
            </div>
            <div class="player-score">
                <input type="number" id="score1" placeholder="分数" value="0">
            </div>
        </div>
        
        <div class="game-area">
            <div class="controls">
                <button id="resetBtn" title="重置游戏">↻</button>
            </div>
            
            <div class="game-board">
                <!-- 第一行是汉字输入，下面10行是游戏格子 -->
            </div>
        </div>
        
        <div class="player-info player-right">
            <div class="player-name">
                <input type="text" id="player2" placeholder="玩家2">
            </div>
            <div class="player-score">
                <input type="number" id="score2" placeholder="分数" value="0">
            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const gameBoard = document.querySelector('.game-board');
            const resetBtn = document.getElementById('resetBtn');
            const score1Input = document.getElementById('score1');
            const score2Input = document.getElementById('score2');
            const player1Input = document.getElementById('player1');
            const player2Input = document.getElementById('player2');
            
            const ROWS = 10;
            const COLS = 10;
            const MINES_COUNT = 20; // 20个地雷
            
            let cells = [];
            let mines = [];
            let gameOver = false;
            let chineseInputs = [];
            
            // 初始化游戏
            function initGame() {
                gameBoard.innerHTML = '';
                cells = [];
                mines = [];
                gameOver = false;
                chineseInputs = [];
                
                // 创建汉字输入行（第一行）
                for (let col = 0; col < COLS; col++) {
                    const inputCell = document.createElement('div');
                    inputCell.className = 'chinese-cell';
                    const input = document.createElement('input');
                    input.type = 'text';
                    input.maxLength = 1;
                    input.placeholder = '字';
                    inputCell.appendChild(input);
                    gameBoard.appendChild(inputCell);
                    chineseInputs.push(input);
                }
                
                // 创建游戏格子（下面10行）
                for (let row = 0; row < ROWS; row++) {
                    cells[row] = [];
                    for (let col = 0; col < COLS; col++) {
                        const cell = document.createElement('div');
                        cell.className = 'cell';
                        // 显示初始数字，从左到右按列排序
                        cell.textContent = col * ROWS + row + 1;
                        cell.dataset.row = row;
                        cell.dataset.col = col;
                        
                        cell.addEventListener('click', () => handleCellClick(row, col));
                        
                        gameBoard.appendChild(cell);
                        cells[row][col] = {
                            element: cell,
                            isMine: false,
                            isRevealed: false,
                            distance: 0
                        };
                    }
                }
                
                // 放置地雷
                placeMines();
                
                // 计算每个格子到最近地雷的距离
                calculateDistances();
            }
            
            // 随机放置地雷
            function placeMines() {
                let minesPlaced = 0;
                
                while (minesPlaced < MINES_COUNT) {
                    const row = Math.floor(Math.random() * ROWS);
                    const col = Math.floor(Math.random() * COLS);
                    
                    if (!cells[row][col].isMine) {
                        cells[row][col].isMine = true;
                        mines.push({ row, col });
                        minesPlaced++;
                    }
                }
            }
            
            // 计算每个非地雷格子到最近地雷的曼哈顿距离
            function calculateDistances() {
                for (let row = 0; row < ROWS; row++) {
                    for (let col = 0; col < COLS; col++) {
                        if (!cells[row][col].isMine) {
                            let minDistance = Number.MAX_SAFE_INTEGER;
                            
                            for (const mine of mines) {
                                const distance = Math.abs(row - mine.row) + Math.abs(col - mine.col);
                                if (distance < minDistance) {
                                    minDistance = distance;
                                }
                            }
                            
                            cells[row][col].distance = minDistance;
                        }
                    }
                }
            }
            
            // 处理格子点击
            function handleCellClick(row, col) {
                if (gameOver || cells[row][col].isRevealed) return;
                
                const cell = cells[row][col];
                cell.isRevealed = true;
                cell.element.classList.add('revealed');
                cell.element.style.border = '1px solid #808080';
                
                if (cell.isMine) {
                    // 点击到地雷
                    cell.element.textContent = '💣';
                    cell.element.classList.add('mine');
                    gameOver = true;
                    showExplosion(row, col);
                } else {
                    // 显示距离地雷的格子数
                    cell.element.textContent = cell.distance;
                    
                    // 根据距离设置颜色
                    if (cell.distance === 1) {
                        cell.element.classList.add('distance-1');
                    } else if (cell.distance === 2) {
                        cell.element.classList.add('distance-2');
                    } else {
                        cell.element.classList.add('distance-3-plus');
                    }
                    
                    // 检查游戏是否胜利
                    checkWin();
                }
            }
            
            // 显示爆炸特效
            function showExplosion(row, col) {
                // 播放爆炸声音
                playExplosionSound();
                
                const overlay = document.createElement('div');
                overlay.className = 'explosion-overlay';
                
                const explosion = document.createElement('div');
                explosion.className = 'explosion';
                explosion.textContent = '💥';
                
                overlay.appendChild(explosion);
                document.querySelector('.game-area').appendChild(overlay);
                
                // 显示所有地雷
                for (const mine of mines) {
                    const mineCell = cells[mine.row][mine.col].element;
                    mineCell.textContent = '💣';
                    mineCell.classList.add('mine', 'revealed');
                    mineCell.style.border = '1px solid #808080';
                }
                
                // 爆炸效果停留不动，不消失
            }
            
            // 播放爆炸声音
            function playExplosionSound() {
                try {
                    // 创建一个简单的爆炸声音
                    const audioContext = new (window.AudioContext || window.webkitAudioContext)();
                    const duration = 2; // 2秒
                    const sampleRate = audioContext.sampleRate;
                    const numFrames = duration * sampleRate;
                    const buffer = audioContext.createBuffer(1, numFrames, sampleRate);
                    const data = buffer.getChannelData(0);
                    
                    // 生成爆炸声音
                    for (let i = 0; i < numFrames; i++) {
                        // 创建爆炸声波
                        const t = i / sampleRate;
                        // 低频噪声模拟爆炸
                        data[i] = (Math.random() * 2 - 1) * Math.exp(-t * 3) * Math.sin(t * 50 * Math.PI * 2);
                    }
                    
                    const source = audioContext.createBufferSource();
                    source.buffer = buffer;
                    source.connect(audioContext.destination);
                    source.start();
                } catch (e) {
                    console.log("音频播放失败:", e);
                }
            }
            
            // 重置游戏板（保留汉字和玩家信息）
            function resetGameBoard() {
                // 移除爆炸效果
                const explosionOverlay = document.querySelector('.explosion-overlay');
                if (explosionOverlay) {
                    explosionOverlay.remove();
                }
                
                gameBoard.innerHTML = '';
                cells = [];
                mines = [];
                gameOver = false;
                
                // 创建汉字输入行（第一行）
                const savedInputs = chineseInputs.map(input => input.value);
                chineseInputs = [];
                
                for (let col = 0; col < COLS; col++) {
                    const inputCell = document.createElement('div');
                    inputCell.className = 'chinese-cell';
                    const input = document.createElement('input');
                    input.type = 'text';
                    input.maxLength = 1;
                    input.placeholder = '字';
                    input.value = savedInputs[col] || '';
                    inputCell.appendChild(input);
                    gameBoard.appendChild(inputCell);
                    chineseInputs.push(input);
                }
                
                // 创建游戏格子（下面10行）
                for (let row = 0; row < ROWS; row++) {
                    cells[row] = [];
                    for (let col = 0; col < COLS; col++) {
                        const cell = document.createElement('div');
                        cell.className = 'cell';
                        // 显示初始数字，从左到右按列排序
                        cell.textContent = col * ROWS + row + 1;
                        cell.dataset.row = row;
                        cell.dataset.col = col;
                        
                        cell.addEventListener('click', () => handleCellClick(row, col));
                        
                        gameBoard.appendChild(cell);
                        cells[row][col] = {
                            element: cell,
                            isMine: false,
                            isRevealed: false,
                            distance: 0
                        };
                    }
                }
                
                // 放置地雷
                placeMines();
                
                // 计算每个格子到最近地雷的距离
                calculateDistances();
            }
            
            // 检查游戏是否胜利
            function checkWin() {
                let unrevealedSafeCells = 0;
                
                for (let row = 0; row < ROWS; row++) {
                    for (let col = 0; col < COLS; col++) {
                        if (!cells[row][col].isMine && !cells[row][col].isRevealed) {
                            unrevealedSafeCells++;
                        }
                    }
                }
                
                if (unrevealedSafeCells === 0) {
                    gameOver = true;
                    
                    const overlay = document.createElement('div');
                    overlay.className = 'game-overlay';
                    overlay.innerHTML = `
                        <div>恭喜获胜!</div>
                        <button class="restart-btn">再玩一次</button>
                    `;
                    
                    document.body.appendChild(overlay);
                    
                    overlay.querySelector('.restart-btn').addEventListener('click', function() {
                        document.body.removeChild(overlay);
                        resetGameBoard();
                    });
                }
            }
            
            // 重置游戏
            resetBtn.addEventListener('click', function() {
                resetGameBoard();
            });
            
            // 初始化游戏
            initGame();
        });
    </script>
</body>
